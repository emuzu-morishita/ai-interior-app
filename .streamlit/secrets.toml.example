# Streamlit Cloud の Secrets 管理画面にこの内容を貼り付けてください。

# テキスト生成（GPT-4o mini）+ 画像生成（gpt-image-1）
OPENAI_API_KEY = "your_openai_api_key_here"

# 楽天商品検索 API（2026年新仕様。類似商品表示）
# 取得先: https://webservice.rakuten.co.jp/
# applicationId(UUID形式) + accessKey(pk_で始まる) の両方が必要
RAKUTEN_APP_ID = "your_rakuten_application_id_uuid_here"
RAKUTEN_ACCESS_KEY = "pk_your_rakuten_access_key_here"
# アプリ登録時の「許可されたWebサイト」と一致させる（Origin/Refererに使用）
RAKUTEN_ORIGIN = "https://ai-interior-app-emuzu-trial.streamlit.app"

# Yahoo!ショッピング API（類似商品表示）
# 取得先: https://e.developer.yahoo.co.jp/register
YAHOO_APP_ID = "your_yahoo_client_id_here"
