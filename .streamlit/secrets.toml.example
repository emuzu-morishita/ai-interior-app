# Streamlit Cloud の Secrets 管理画面にこの内容を貼り付けてください。

# テキスト生成（GPT-4o mini）+ 画像生成（gpt-image-1）
OPENAI_API_KEY = "your_openai_api_key_here"

# 楽天商品検索 API（類似商品表示）
# 取得先: https://webservice.rakuten.co.jp/
RAKUTEN_APP_ID = "your_rakuten_app_id_here"

# Yahoo!ショッピング API（類似商品表示）
# 取得先: https://e.developer.yahoo.co.jp/register
YAHOO_APP_ID = "your_yahoo_client_id_here"
